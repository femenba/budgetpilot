VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — server-side only (Vercel serverless functions)
# Use the service role key so webhook updates bypass RLS.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — server-side only (Vercel serverless functions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — transactional email (Vercel serverless functions)
# Sign up at resend.com, verify budgetpilotapp.com, then create an API key.
RESEND_API_KEY=re_...
